# Create .env.studio.local from this template.
# The local file is ignored by Git and read only by the local Studio server.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=juanlord-portfolio-media
R2_PUBLIC_BASE_URL=

# Local safety rails. Uploads stop before either threshold is reached.
R2_MAX_STORAGE_GB=9
R2_MAX_CLASS_A_OPERATIONS=900000
